<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <title>Slideshow Fully Kiosk</title>
  <style>
    html, body {
      margin: 0;
      padding: 0;
      height: 100%;
      width: 100%;
      background-color: black;
      overflow: hidden;
    }
    #slideshow {
      width: 100%;
      height: 100%;
      background-position: center;
      background-size: cover;
      background-repeat: no-repeat;
      transition: background-image 1s ease-in-out;
    }
  </style>
</head>
<body>
  <div id="slideshow"></div>

  <script>
    // Lista di keyword per immagini casuali
    const keywords = ["nature", "landscape", "city"];
    const slideshow = document.getElementById("slideshow");
    const interval = 10000; // tempo tra un'immagine e l'altra in ms (10 secondi)

    function getRandomKeyword() {
      return keywords[Math.floor(Math.random() * keywords.length)];
    }

    function loadImage() {
      const keyword = getRandomKeyword();
      const url = `https://source.unsplash.com/1920x1200/?${keyword}&sig=${Math.random()}`;
      slideshow.style.backgroundImage = `url('${url}')`;
    }

    // Carica la prima immagine subito
    loadImage();

    // Cambia immagine ogni intervallo
    setInterval(loadImage, interval);
  </script>
</body>
</html>
